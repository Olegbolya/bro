# Шаблон конфигурации Nginx для проекта БРО.
# Использование:
#   1. Скопируйте в /etc/nginx/sites-available/bro
#   2. Замените все вхождения "ваш-домен.ru" на реальный домен
#   3. Выполните: ln -s /etc/nginx/sites-available/bro /etc/nginx/sites-enabled/
#   4. Проверьте: nginx -t
#   5. Перезагрузите: systemctl reload nginx

server {
    listen 80;
    # Укажите ваш домен (можно несколько через пробел)
    server_name ваш-домен.ru www.ваш-домен.ru;

    # Максимальный размер загружаемых файлов (для изображений в новостях)
    client_max_body_size 10M;

    # Статические файлы Next.js отдаём напрямую — без Node.js, быстро
    location /_next/static/ {
        alias /var/www/bro/.next/static/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Загруженные изображения (если используется локальное хранилище)
    location /uploads/ {
        alias /var/www/bro/public/uploads/;
        expires 30d;
        add_header Cache-Control "public";
    }

    # Все остальные запросы — проксируем к Next.js (порт 3000)
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

# После получения SSL-сертификата через certbot --nginx
# конфигурация обновится автоматически: добавится блок для HTTPS (443)
# и редирект с HTTP на HTTPS.
