# ╔══════════════════════════════════════════════════════════════════╗
# ║              ШАБЛОН ПЕРЕМЕННЫХ ОКРУЖЕНИЯ — БРО                  ║
# ║  Скопируйте этот файл в .env.local (локально) или .env (VPS)    ║
# ║  и заполните своими значениями. Не коммитьте реальные секреты!  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── База данных PostgreSQL ────────────────────────────────────────────────────
#
# Основной URL подключения. Форматы:
#   Supabase:  postgresql://postgres.<project>:<password>@<host>.pooler.supabase.com:6543/postgres?pgbouncer=true
#   VPS:       postgresql://bro_user:mypassword@localhost:5432/bro_db
#   Docker:    postgresql://postgres:postgres@db:5432/bro
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Прямой URL (без пулера) — нужен только для `npm run db:push` / миграций.
# На VPS совпадает с DATABASE_URL. На Supabase — отдельный direct endpoint (порт 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ─── Сессии ───────────────────────────────────────────────────────────────────
#
# Секретный ключ для шифрования куки iron-session. ОБЯЗАТЕЛЕН.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Минимум 32 символа. При смене — все активные сессии инвалидируются.
#
SESSION_SECRET="замените_на_случайную_строку_минимум_32_символа"

# ─── Администратор ────────────────────────────────────────────────────────────
#
# bcrypt-хеш пароля администратора. Сам пароль здесь НЕ хранится.
# Сгенерировать хеш:
#   node -e "const b=require('bcryptjs'); b.hash('ВАШ_ПАРОЛЬ',10).then(console.log)"
# Или онлайн: https://bcrypt.online (cost factor = 10)
#
ADMIN_PASSWORD_HASH="$2a$10$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ─── Публичный URL сайта ──────────────────────────────────────────────────────
#
# Используется для sitemap.xml. Без слеша в конце.
# Пример: https://bro.example.com
#
NEXT_PUBLIC_BASE_URL="https://ваш-домен.ru"

# ─── Хранилище изображений ────────────────────────────────────────────────────
#
# Заполните ОДИН из трёх блоков ниже. Остальные оставьте пустыми.
# Если все пустые — файлы сохраняются локально в public/uploads/ (рекомендуется для VPS).

# --- Вариант 1: Vercel Blob (только для деплоя на Vercel) ---
# Получить токен: Vercel Dashboard → проект → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=""

# --- Вариант 2: S3-совместимое хранилище (Yandex Cloud, MinIO, AWS S3) ---
# Yandex Cloud Object Storage:
#   S3_ENDPOINT=https://storage.yandexcloud.net
#   S3_REGION=ru-central1
#   S3_BUCKET_NAME=имя-вашего-бакета
#   S3_FORCE_PATH_STYLE=false
# MinIO (локальный):
#   S3_ENDPOINT=http://localhost:9000
#   S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=""
S3_REGION="ru-central1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
# Публичный домен для доступа к файлам (опционально, например CDN):
S3_PUBLIC_URL=""
# Для MinIO и других не-AWS провайдеров установить true:
S3_FORCE_PATH_STYLE="false"

# --- Вариант 3: Локальные файлы ---
# Настройка не требуется. Файлы сохраняются в public/uploads/news/.
# Убедитесь, что папка public/uploads/ существует и у процесса есть права на запись.
